<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>NG's Daily Roleta</title>
    <style>
        body {
            font-family: 'Courier New', Courier, monospace;
            background-color: #2c2c2c;
            color: #ff69b4; /* Pink like NG's dress */
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
        }
        #wheel-container {
            position: relative;
            width: 300px;
            height: 300px;
            border: 5px solid #ff69b4;
            border-radius: 50%;
            overflow: hidden;
            transition: transform 3s cubic-bezier(0.1, 0, 0.2, 1);
        }
        .wheel-part {
            position: absolute;
            width: 100%;
            height: 100%;
            clip-path: polygon(50% 50%, 50% 0, 100% 0, 100% 50%);
            background-color: #444;
            display: flex;
            align-items: center;
            justify-content: center;
            transform-origin: 50% 50%;
        }
        #pointer {
            position: absolute;
            top: -20px;
            width: 0; 
            height: 0; 
            border-left: 20px solid transparent;
            border-right: 20px solid transparent;
            border-top: 40px solid gold;
            z-index: 10;
        }
        button {
            margin-top: 30px;
            padding: 15px 30px;
            background-color: #ff69b4;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
        }
        button:hover { background-color: #ff1493; }
        #result { margin-top: 20px; font-size: 1.5rem; font-weight: bold; color: gold; }
    </style>
</head>
<body>

    <h1>Pick a Task!</h1>
    <div id="pointer"></div>
    <div id="wheel-container" id="wheel">
        <div class="wheel-part" style="transform: rotate(0deg); background: #555;">Walk</div>
        <div class="wheel-part" style="transform: rotate(90deg); background: #666;">Lifts</div>
        <div class="wheel-part" style="transform: rotate(180deg); background: #777;">Pixels</div>
        <div class="wheel-part" style="transform: rotate(270deg); background: #888;">Rest</div>
    </div>

    <button onclick="spin()">SPIN THE WHEEL</button>
    <div id="result"></div>

    <p><a href="../index.html" style="color: gray; text-decoration: none;">← Back to Studio</a></p>

    <script>
        function spin() {
            const wheel = document.getElementById('wheel-container');
            const resultDisplay = document.getElementById('result');
            const options = ["Rest", "Pixels", "Lifts", "Walk"]; // Matches rotation
            
            // Randomly spin between 2 to 5 full circles + extra degrees
            const randomDegree = Math.floor(Math.random() * 360) + 720; 
            wheel.style.transform = `rotate(${randomDegree}deg)`;
            
            resultDisplay.innerText = "Spinning...";
            
            setTimeout(() => {
                const actualDegree = randomDegree % 360;
                // Simple logic to determine which slice the pointer is on
                let task = "";
                if (actualDegree >= 0 && actualDegree < 90) task = "Rest";
                else if (actualDegree >= 90 && actualDegree < 180) task = "Pixels";
                else if (actualDegree >= 180 && actualDegree < 270) task = "Lifts";
                else task = "Walk";
                
                resultDisplay.innerText = "Today's Focus: " + task;
            }, 3000); // Wait for the 3s animation to finish
        }
    </script>
</body>
</html>
